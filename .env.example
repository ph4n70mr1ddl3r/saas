# Environment
RUST_LOG=info

# REQUIRED: Generate with: openssl rand -base64 48
JWT_SECRET=__GENERATE_A_SECRET_DO_NOT_USE_THIS_VALUE__

# CORS origin (used by all backend services)
CORS_ORIGIN=http://localhost:3000

# API base URL (used by frontend)
API_BASE_URL=http://localhost:8000

# NATS
NATS_URL=nats://localhost:4222

# Database URLs (SQLite)
IAM_DATABASE_URL=sqlite:./data/iam.db
CONFIG_DATABASE_URL=sqlite:./data/config.db
EMPLOYEE_DATABASE_URL=sqlite:./data/employee.db
PAYROLL_DATABASE_URL=sqlite:./data/payroll.db
BENEFITS_DATABASE_URL=sqlite:./data/benefits.db
TIME_LABOR_DATABASE_URL=sqlite:./data/time_labor.db
RECRUITING_DATABASE_URL=sqlite:./data/recruiting.db
GL_DATABASE_URL=sqlite:./data/general_ledger.db
AP_DATABASE_URL=sqlite:./data/accounts_payable.db
AR_DATABASE_URL=sqlite:./data/accounts_receivable.db
FIXED_ASSETS_DATABASE_URL=sqlite:./data/fixed_assets.db
CASH_MGMT_DATABASE_URL=sqlite:./data/cash_management.db
EXPENSE_MGMT_DATABASE_URL=sqlite:./data/expense_mgmt.db
PERFORMANCE_DATABASE_URL=sqlite:./data/performance.db
INVENTORY_DATABASE_URL=sqlite:./data/inventory.db
PROCUREMENT_DATABASE_URL=sqlite:./data/procurement.db
ORDER_MGMT_DATABASE_URL=sqlite:./data/order_management.db
MANUFACTURING_DATABASE_URL=sqlite:./data/manufacturing.db

# Service Ports
GATEWAY_PORT=8000
IAM_PORT=8001
CONFIG_PORT=8002
EMPLOYEE_PORT=8010
PAYROLL_PORT=8011
BENEFITS_PORT=8012
TIME_LABOR_PORT=8013
RECRUITING_PORT=8014
PERFORMANCE_PORT=8015
GL_PORT=8020
AP_PORT=8021
AR_PORT=8022
FIXED_ASSETS_PORT=8023
CASH_MGMT_PORT=8024
EXPENSE_MGMT_PORT=8025
INVENTORY_PORT=8030
PROCUREMENT_PORT=8031
ORDER_MGMT_PORT=8032
MANUFACTURING_PORT=8033
FRONTEND_PORT=3000
